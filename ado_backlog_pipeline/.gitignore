# ado_backlog_pipeline — bundle-level gitignore
# Keeps developer-local files out of version control.
# This makes the bundle self-contained — credentials and personal logs
# never leak into working code branches.

# Credentials — copy .env.example to .env and fill in your values
.env

# Personal daily work log — copy work-log.csv.template to work-log.csv
data/work-log.csv
