# hackathon-project — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env in the ado_backlog_pipeline/ folder and fill in values.
#
#   cp .env.example .env        (Linux / macOS / Git Bash)
#   copy .env.example .env      (Windows CMD / PowerShell)
#
# .env is gitignored — your credentials are NEVER committed.
# This .env.example file IS committed — keep it up-to-date for the team.
#
# GitHub Actions equivalents are listed for each variable — add them at:
#   https://github.com/Terraformers-Anonymous/hackathon-project/settings/secrets/actions
# ─────────────────────────────────────────────────────────────────────────────


# ── Azure DevOps ──────────────────────────────────────────────────────────────
# Personal Access Token — the ONLY credential required for all 9 pipeline scripts.
# Generate at: https://dev.azure.com/<YOUR_ORG>/_usersSettings/tokens
#   Scopes required:  Work Items — Read, write & manage
#                     Code — Read  (for branch artifact linking)
#
# GitHub Actions secret name: ADO_PAT
# VS Code MCP: prompted interactively via mcp.json inputs.ado_pat

ADO_PAT=your_ado_personal_access_token_here


# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Required by all 5 agent HTTP servers (pr_review, issue_triage, log_analyst,
# test_generator, release_notes) and by rag/ingest/ingest_kb.py.
#
# Endpoint format: https://<resource-name>.openai.azure.com/
# Deployment name: the name you gave your gpt-4o deployment in Azure AI Studio.
#
# GitHub Actions secret names: AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_KEY, AZURE_OPENAI_DEPLOYMENT

AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o


# ── Azure AI Search ───────────────────────────────────────────────────────────
# Required by RAG wiring in pr_review agent and ingest_kb.py indexer.
# Endpoint format: https://<search-resource>.search.windows.net
# Index name: name of the HNSW vector index created by ingest_kb.py.
#
# GitHub Actions secret names: AZURE_SEARCH_ENDPOINT, AZURE_SEARCH_KEY, AZURE_SEARCH_INDEX

AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_admin_key_here
AZURE_SEARCH_INDEX=hackathon-standards


# ── Azure AI Projects (Foundry) ───────────────────────────────────────────────
# Optional — required only if you use azure-ai-projects SDK instead of direct
# azure-openai SDK for agent calls. Connection string from Azure AI Foundry portal.
#
# GitHub Actions secret name: AZURE_AI_PROJECT_CONNECTION_STRING

AZURE_AI_PROJECT_CONNECTION_STRING=<region>.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>


# ── GitHub ────────────────────────────────────────────────────────────────────
# Fine-grained PAT or classic PAT for GitHub API calls from local scripts.
# The GITHUB_TOKEN secret is auto-injected in GitHub Actions — this is only
# needed when running scripts locally against the GitHub API.
#
# Required scopes: repo (Contents, Issues, Pull Requests), project (read/write)
# GitHub Actions secret name: PROJECT_TOKEN (for add-to-project.yml — needs project scope)

GITHUB_TOKEN=your_github_personal_access_token_here
PROJECT_TOKEN=your_github_project_scoped_token_here


# ── Azure Monitor / Application Insights ─────────────────────────────────────
# Required by azure-monitor-opentelemetry tracing in agent HTTP servers.
# Connection string from: Azure Portal → App Insights resource → Overview.
#
# GitHub Actions secret name: APPLICATIONINSIGHTS_CONNECTION_STRING

APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/


# ── Azure Key Vault (optional, production hardening) ─────────────────────────
# When deployed to Azure Functions / Container Apps, all of the above secrets
# can be fetched from Key Vault at runtime using DefaultAzureCredential.
# Set this URI to enable Key Vault integration in agent main.py files.
#
# GitHub Actions secret name: AZURE_KEYVAULT_URI

AZURE_KEYVAULT_URI=https://<your-keyvault>.vault.azure.net/

